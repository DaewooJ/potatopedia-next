# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# analytics data dumps + manual exports (see scripts/data/README.md)
/scripts/data/plausible/
/scripts/data/bing/
/scripts/data/gsc/
/scripts/reports/weekly/

# claude code local config
.claude/

# generic logs (specific debug-log patterns already above)
*.log
__pycache__/
